# Security
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# Database
DATABASE_URL=sqlite:///data/jobs.db

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_ANNUAL=price_your_annual_price_id

# Email (Resend API)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=NewWhale Career <noreply@newwhaletech.com>
APP_BASE_URL=https://newwhaletech.com
EMAIL_VERIFICATION_EXPIRY_MINUTES=30

# Gmail OAuth (for outreach mailbox connect)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Optional override; defaults to {APP_BASE_URL}/outreach/gmail/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://newwhaletech.com/outreach/gmail/callback

# Outlook/Microsoft OAuth (for outreach mailbox connect)
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret
# Optional override; defaults to {APP_BASE_URL}/outreach/outlook/callback
# MICROSOFT_OAUTH_REDIRECT_URI=https://newwhaletech.com/outreach/outlook/callback

# LLM API (choose one)
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# File Upload Configuration
UPLOAD_MAX_SIZE_MB=10
ALLOWED_RESUME_EXTENSIONS=pdf,docx

# Flask Configuration
FLASK_DEBUG=True
FLASK_PORT=5000
HOST=0.0.0.0
JOB_EXPORT_TOKEN=change-this-internal-feed-token

# Rate Limiting
FREE_TIER_DAILY_ASSESSMENTS=3

# Chrome/Chromium (auto-detected if not set)
# CHROME_BINARY_PATH=/usr/bin/chromium-browser
# CHROMEDRIVER_PATH=/usr/bin/chromedriver

# Job scraper feed
# Where the weekly importer pulls the freshest jobs CSV from. This is produced
# by the dylanlee20/job-scraper GitHub Action. For the PRIVATE repo, use the
# contents API endpoint below and supply a token with read access.
# If JOBS_CSV_URL is unset, the importer falls back to the local file at
# JOBS_CSV_PATH (~/whalestreet/services/job-scraper/jobs_finance.csv).
JOBS_CSV_URL=https://api.github.com/repos/dylanlee20/job-scraper/contents/jobs_finance.csv?ref=main
JOBS_CSV_TOKEN=github_pat_with_read_access_to_job_scraper
# Optional: override the on-disk path the CSV is written to / read from.
# JOBS_CSV_PATH=/root/whalestreet/services/job-scraper/jobs_finance.csv
